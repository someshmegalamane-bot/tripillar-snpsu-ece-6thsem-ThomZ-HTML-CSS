<html>
    <head>
        <title> Flexbox Example </title>
    </head>
        <style>
            .container {
                display: flex;
                background-color: rgb(204, 86, 13);
                grid-template-columns: auto auto auto   ;

            }
            .container > div {
                background-color: rgb(241, 196, 17);
                margin: 20px;
                font-size: 20px;
                padding: 10px;

            }
            </style>
<body>
    <div class="container">
        <div> product 1 </div>
        <div> product 2 </div>
        <div> product 4 </div>
        <div> product 5 </div>
        <div> product 6 </div>
    </div>
</body>
</html>